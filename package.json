{
  "name": "markdown-code-embedder",
  "publisher": "giob22",
  "displayName": "Markdown Code Embedder",
  "description": "Embed code snippets from external files into Markdown documents.",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/giob22/Markdown-Code-Embedder.git"
  },
  "version": "0.1.6",
  "engines": {
    "vscode": "^1.74.0"
  },
  "keywords": [
    "markdown",
    "documentation",
    "snippet",
    "dynamic",
    "embed",
    "import code",
    "include",
    "inject",
    "sync",
    "literate",
    "code docs",
    "code snippets",
    "live docs"
  ],
  "categories": [
    "Programming Languages",
    "Notebooks",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.md",
    "onLanguage:markdown",
    "onCommand:markdown-embed.update"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdown-embed.update",
        "title": "Update Code Embeds"
      },
      {
        "command": "markdown-embed.updateSingle",
        "title": "Update Single Code Embed"
      },
      {
        "command": "markdown-embed.goToSource",
        "title": "Go to Embed Source File"
      },
      {
        "command": "markdown-embed.lock",
        "title": "Lock Code Embed"
      },
      {
        "command": "markdown-embed.unlock",
        "title": "Unlock Code Embed"
      }
    ],
    "configuration": {
      "title": "Markdown Embedder",
      "properties": {
        "markdownEmbedder.autoUpdate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically update embeds in markdown files when a referenced source file is saved."
        }
      }
    },
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.3"
  }
}